{
  "name": "hypemuzik-desktop",
  "private": true,
  "version": "0.1.10",
  "type": "module",
  "description": "HypeMuzik — system-wide audio enhancement desktop app (Tauri + React).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "tauri:prebuild": "node scripts/build-sidecar.mjs && tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "app:dev": "tauri dev",
    "build:app": "tauri build",
    "build:debug": "tauri build --debug",
    "build:mac": "tauri build --target universal-apple-darwin"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "hls.js": "^1.6.16",
    "lucide-react": "1.20.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "^0.184.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@tauri-apps/cli": "2.11.2",
    "@types/node": "^22.19.21",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "6.0.2",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.7.0"
}