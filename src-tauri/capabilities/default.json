{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities granted to the main window. App-defined commands are always available; this grants the core and plugin commands the UI needs.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-fullscreen",
    "opener:default",
    "store:default",
    "dialog:default",
    "dialog:allow-open",
    "updater:default",
    "process:allow-restart"
  ]
}
