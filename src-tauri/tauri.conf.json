{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HypeMuzik",
  "version": "0.1.14",
  "identifier": "com.hypemuzik.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm tauri:prebuild"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "HypeMuzik",
        "width": 1180,
        "height": 1060,
        "minWidth": 340,
        "minHeight": 200,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "center": true,
        "theme": "Dark",
        "backgroundColor": "#0A0B0E"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; media-src 'self' blob: http://127.0.0.1:* http://localhost:*; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/hm-visualizer"
    ],
    "resources": {
      "../crates/hm-visualizer/presets/*.milk": "presets/",
      "drivers/HypeMuzikAudio/*": "drivers/HypeMuzikAudio/"
    },
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "fileAssociations": [
      {
        "ext": [
          "mp3",
          "flac",
          "wav",
          "ogg",
          "oga",
          "m4a",
          "aac",
          "opus"
        ],
        "name": "Audio",
        "description": "Audio file",
        "role": "Viewer",
        "mimeType": "audio/mpeg,audio/flac,audio/x-wav,audio/ogg,audio/mp4,audio/aac,audio/opus"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCRDYyNjFGREVEQjRGQzkKUldUSlQ5dmVIeWJXMjA4Y3dkMnE3QVlnNHE5amZjZFo4UzJRS0FlMTE4eFlwb2lsdlpXRisxRjIK",
      "endpoints": [
        "https://github.com/Lw-Muzik/hype-dsp/releases/latest/download/latest.json",
        "https://cdn.crabnebula.app/dl/hypemuzik/hypemuzik/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
